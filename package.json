{
	"name": "org-roam-ui-lite",
	"private": true,
	"type": "module",
	"bin": {
		"org-roam-ui-lite": "./dist/backend/dist/cli.mjs"
	},
	"workspaces": [
		"packages/backend",
		"packages/rehype-mathjax",
		"packages/rehype-mermaid",
		"packages/frontend",
		"packages/emacs",
		"packages/example"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/cytoscape": "^3.31.0",
		"@types/hast": "^3.0.4",
		"@types/jest": "^30.0.0",
		"@types/license-checker": "^25.0.6",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^25.6.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"happy-dom": "^20.9.0",
		"lefthook": "^2.1.6",
		"license-checker": "^25.0.1",
		"npm-run-all": "^4.1.5",
		"openapi-typescript": "^7.13.0",
		"serve": "^14.2.6",
		"tsdown": "^0.22.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.11",
		"vitest": "^4.1.5"
	},
	"scripts": {
		"typegen": "node openapi.ts | tee packages/frontend/src/api/api.d.ts packages/backend/src/api.d.ts > /dev/null && biome format --write packages/frontend/src/api/api.d.ts packages/backend/src/api.d.ts",
		"dev": "npm-run-all -p dev:frontend 'dev:backend -- {@}' --",
		"dev:backend": "npm --workspace=packages/backend run dev --",
		"dev:frontend": "npm --workspace=packages/frontend run dev --",
		"build": "npm run typegen && npm run build:workspaces && npm run build:dist",
		"build:dist": "node ./scripts/build.ts",
		"build:workspaces": "npm run build --workspaces --if-present",
		"export": "npm run build && node ./scripts/export.ts -r ./dist",
		"dump": "npm --workspace=packages/backend run dump --",
		"populate": "npm --workspace=packages/backend run populate --",
		"serve": "npm --workspace=packages/backend run serve --",
		"example:export": "npm --workspace=packages/example run export",
		"example:populate": "npm --workspace=packages/example run populate",
		"example:serve": "npm --workspace=packages/example run serve",
		"check": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"test": "vitest",
		"test:ui": "vitest --ui"
	},
	"version": "0.3.1"
}
