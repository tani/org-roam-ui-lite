{
	"name": "org-roam-ui-lite",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/cytoscape": "^3.31.0",
		"@types/hast": "^3.0.4",
		"@types/jest": "^30.0.0",
		"@types/license-checker": "^25.0.6",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^25.6.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260509.2",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"jsdom": "^29.1.1",
		"lefthook": "^2.1.6",
		"license-checker": "^25.0.1",
		"npm-run-all": "^4.1.5",
		"openapi-typescript": "^7.13.0",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vitest": "^4.1.5"
	},
	"scripts": {
		"prebuild": "node openapi.ts | tee packages/frontend/src/api/api.d.ts packages/backend/src/api.d.ts > /dev/null && biome format --write packages/frontend/src/api/api.d.ts packages/backend/src/api.d.ts",
		"build": "npm run build --workspaces && node ./scripts/build.ts",
		"export": "npm run build && node ./scripts/export.ts -r ./dist",
		"dev": "npm-run-all -p dev:frontend 'dev:backend -- {@}' --",
		"dev:frontend": "npm --workspace=packages/frontend run dev --",
		"dev:backend": "npm --workspace=packages/backend run dev --",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"check": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui"
	},
	"version": "0.2.9",
	"dependencies": {
		"shiki": "^4.0.2"
	}
}
